PYTHONPATH=src
USE_SYMENGINE=1
CC=/usr/bin/gcc-14
CXX=/usr/bin/g++-14

# If CMake cannot find Boost, set CMAKE_PREFIX_PATH to the Boost installation prefix:
# CMAKE_PREFIX_PATH="/usr/local"

# If your system only has shared Boost libraries (e.g., some Linux distros),
# add -DUSE_STATIC_LINK=OFF to CMAKE_ARGS:
# CMAKE_ARGS="-DUSE_STATIC_LINK=OFF"

# Both options can be combined:
# CMAKE_PREFIX_PATH="/usr/local"
# CMAKE_ARGS="-DCMAKE_PREFIX_PATH=/usr/local -DUSE_STATIC_LINK=OFF"